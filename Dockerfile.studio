# Stage 1: build the React frontend
FROM node:22-slim AS frontend-build
WORKDIR /frontend
COPY frontend/package.json frontend/package-lock.json ./
RUN npm ci --silent --legacy-peer-deps
COPY frontend/ ./
# VITE_YJS_WS_URL is baked into the bundle at build time. Set via Docker
# build args (or leave empty for single-user mode + BroadcastChannel demo).
#   docker build --build-arg VITE_YJS_WS_URL=wss://collab.percy.app ...
ARG VITE_YJS_WS_URL=""
ENV VITE_YJS_WS_URL=${VITE_YJS_WS_URL}
ARG GIT_SHA="dev"
ARG BUILD_TIME="unknown"
ENV VITE_GIT_SHA=${GIT_SHA}
RUN npm run build

# Stage 2: Python workspace API
FROM python:3.13-slim

ENV PYTHONDONTWRITEBYTECODE=1
ENV PYTHONUNBUFFERED=1

WORKDIR /app

# System libs needed by matplotlib, Pillow, and PyMuPDF
RUN apt-get update && apt-get install -y --no-install-recommends \
    libgl1 libglib2.0-0 libsm6 libxrender1 libxext6 \
    libfreetype6 libfontconfig1 fontconfig \
    fonts-liberation \
    && fc-cache -f \
    && rm -rf /var/lib/apt/lists/*

RUN python -m pip install --no-cache-dir --upgrade pip \
    && python -m pip install --no-cache-dir \
       "fastapi>=0.110.0" \
       "uvicorn[standard]>=0.27.0" \
       "python-multipart>=0.0.9" \
       "Pillow>=10.0.0" \
       "PyMuPDF>=1.23.0" \
       "matplotlib>=3.8.0" \
       "lxml>=5.0.0" \
       "XlsxWriter>=3.0.0" \
       "boto3>=1.34.0" \
       "anthropic>=0.40.0" \
       "bcrypt>=5.0.0" \
       "PyJWT>=2.10.0" \
       "psycopg2-binary>=2.9.9" \
       "email-validator>=2.0.0" \
       "authlib>=1.7.0" \
       "pydantic[email]>=2.0.0" \
       "cryptography>=42.0.0" \
       "httpx>=0.27.0"

# Percy source packages
COPY src/percy /app/src/percy
COPY src/pptx  /app/src/pptx
ENV PYTHONPATH=/app/src

# App backend
COPY app/__init__.py /app/app/__init__.py
COPY app/backend     /app/app/backend
COPY app/cloud       /app/app/cloud

# Pre-baked Template Set + demo deck snapshots seeded by init_db on boot.
# Without this dir copied, seed_demo_brand_sets() finds nothing and the
# /api/showcase endpoint serves no brands.
COPY demo_brands     /app/demo_brands

# DB file lives in /tmp on App Runner (instance is ephemeral; in prod we use Postgres)
ENV PERCY_AUTH_DB=/tmp/percy_app.db
ARG GIT_SHA="dev"
ARG BUILD_TIME="unknown"
ENV GIT_SHA=${GIT_SHA}
ENV BUILD_TIME=${BUILD_TIME}

# Pre-built frontend from Stage 1
COPY --from=frontend-build /frontend/dist /app/frontend/dist

EXPOSE 8000

CMD ["uvicorn", "app.backend.main:app", "--host", "0.0.0.0", "--port", "8000"]
